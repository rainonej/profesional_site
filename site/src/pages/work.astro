---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import settings from '../content/settings/main.json';
import { getBase, sortByDateDesc } from '../lib/utils';

const projects = await getCollection('projects');
const sorted = sortByDateDesc(projects);
const base = getBase();
---

<Layout title={`Work — ${settings.name}`}>
  <section class="mx-auto max-w-5xl px-6 pb-24 pt-40">
    <p
      class="mb-6 text-xs font-medium uppercase tracking-[0.25em] text-amber-800"
    >
      Portfolio
    </p>
    <h1 class="mb-16 font-serif text-5xl font-bold leading-tight md:text-6xl">
      My Work
    </h1>

    {
      sorted.length === 0 ? (
        <p class="text-lg text-stone-400">Projects coming soon.</p>
      ) : (
        <div class="grid gap-12 md:grid-cols-2">
          {sorted.map((project) => {
            const p = project.data;
            const detailUrl = `${base}/work/${project.id}`;
            return (
              <article class="group">
                <a href={detailUrl} class="block">
                  {p.image ? (
                    <div class="mb-5 aspect-[16/9] overflow-hidden rounded-2xl bg-stone-100">
                      <img
                        src={p.image}
                        alt={p.title}
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      />
                    </div>
                  ) : (
                    <div class="mb-5 flex aspect-[16/9] items-center justify-center rounded-2xl bg-amber-50">
                      <span class="font-serif text-6xl italic text-amber-200">
                        {p.title[0]}
                      </span>
                    </div>
                  )}
                </a>
                <div class="mb-2 flex flex-wrap gap-3">
                  {p.tags?.map((tag: string) => (
                    <span class="text-xs font-medium uppercase tracking-widest text-amber-800">
                      {tag}
                    </span>
                  ))}
                </div>
                <h2 class="mb-2 font-serif text-2xl font-bold">
                  <a
                    href={detailUrl}
                    class="transition-colors hover:text-amber-800"
                  >
                    {p.title}
                  </a>
                </h2>
                <p class="mb-4 text-sm leading-relaxed text-stone-500">
                  {p.description}
                </p>
                {p.link ? (
                  <a
                    href={p.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm font-medium underline underline-offset-4 transition-colors hover:text-amber-800"
                  >
                    View project →
                  </a>
                ) : (
                  <a
                    href={detailUrl}
                    class="text-sm font-medium underline underline-offset-4 transition-colors hover:text-amber-800"
                  >
                    View project →
                  </a>
                )}
              </article>
            );
          })}
        </div>
      )
    }
  </section>
</Layout>
