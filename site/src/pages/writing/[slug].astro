---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import ImageOrFallback from '../../components/ImageOrFallback.astro';
import settings from '../../content/settings/main.json';
import { getBase, formatDate } from '../../lib/utils';

export async function getStaticPaths() {
  const posts = await getCollection('writing', ({ data }) => !data.draft);
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const p = entry.data;
const base = getBase();
---

<Layout title={`${p.title} — ${settings.name}`} description={p.description}>
  <article class="mx-auto max-w-3xl px-6 pb-24 pt-40">
    <a
      href={`${base}/writing`}
      class="mb-8 inline-block text-sm text-stone-400 transition-colors hover:text-stone-900"
    >
      ← Back to Writing
    </a>

    <div class="mb-10 aspect-[21/9] overflow-hidden rounded-2xl bg-stone-100">
      <ImageOrFallback
        src={p.image ? `${base}${p.image}` : null}
        alt={p.title}
        fallbackChar={p.title[0]}
        class="h-full w-full object-cover"
        loading="lazy"
      />
    </div>

    <div class="mb-4 flex flex-wrap items-center gap-3">
      <time class="text-xs text-stone-400" datetime={p.date.toISOString()}>
        {formatDate(p.date)}
      </time>
      {
        p.tags?.map((tag: string) => (
          <span class="text-xs font-medium uppercase tracking-widest text-amber-800">
            {tag}
          </span>
        ))
      }
    </div>

    <h1 class="mb-4 font-serif text-4xl font-bold leading-tight md:text-5xl">
      {p.title}
    </h1>

    {
      p.description && (
        <p class="mb-10 text-xl leading-relaxed text-stone-500">
          {p.description}
        </p>
      )
    }

    <div
      class="prose prose-stone prose-headings:font-serif prose-a:text-amber-800 prose-a:underline-offset-4 max-w-none"
    >
      <Content />
    </div>
  </article>
</Layout>
