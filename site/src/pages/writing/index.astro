---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import settings from '../../content/settings/main.json';

const posts = await getCollection('writing', ({ data }) => !data.draft);
const sorted = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title={`Writing — ${settings.name}`}
  description="Essays and reflections on curriculum, equity, and teaching."
>
  <section class="mx-auto max-w-3xl px-6 pb-24 pt-40">
    <p
      class="mb-6 text-xs font-medium uppercase tracking-[0.25em] text-amber-800"
    >
      Writing
    </p>
    <h1 class="mb-4 font-serif text-5xl font-bold leading-tight md:text-6xl">
      Essays & Reflections
    </h1>
    <p class="mb-16 text-lg leading-relaxed text-stone-500">
      Thoughts on curriculum design, equitable learning, teacher development,
      and the practice-to-research bridge.
    </p>

    {
      sorted.length === 0 ? (
        <p class="text-lg text-stone-400">Posts coming soon.</p>
      ) : (
        <div class="divide-y divide-stone-100">
          {sorted.map((post) => {
            const p = post.data;
            const postUrl = `${base}/writing/${post.slug}`;
            return (
              <article class="group py-10 first:pt-0">
                <div class="mb-3 flex flex-wrap items-center gap-3">
                  <time
                    class="text-xs text-stone-400"
                    datetime={p.date.toISOString()}
                  >
                    {p.date.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                  {p.tags?.map((tag: string) => (
                    <span class="text-xs font-medium uppercase tracking-widest text-amber-800">
                      {tag}
                    </span>
                  ))}
                </div>
                <h2 class="mb-3 font-serif text-2xl font-bold leading-snug">
                  <a
                    href={postUrl}
                    class="transition-colors hover:text-amber-800"
                  >
                    {p.title}
                  </a>
                </h2>
                {p.description && (
                  <p class="mb-4 leading-relaxed text-stone-500">
                    {p.description}
                  </p>
                )}
                <a
                  href={postUrl}
                  class="text-sm font-medium underline underline-offset-4 transition-colors hover:text-amber-800"
                >
                  Read more →
                </a>
              </article>
            );
          })}
        </div>
      )
    }
  </section>
</Layout>
