---
import Layout from '../layouts/Layout.astro';
import settings from '../content/settings/main.json';
---

<Layout title={`About — ${settings.name}`} description={settings.bio}>
  <section class="pt-40 pb-24 px-6 max-w-5xl mx-auto">
    <div class="grid md:grid-cols-2 gap-20 items-start">

      <!-- Photo -->
      <div>
        {settings.photo ? (
          <img
            src={settings.photo}
            alt={settings.name}
            class="w-full aspect-[3/4] object-cover rounded-3xl"
          />
        ) : (
          <div class="w-full aspect-[3/4] rounded-3xl bg-amber-50 flex items-center justify-center">
            <span class="font-serif text-9xl text-amber-200 italic">{settings.name[0]}</span>
          </div>
        )}
      </div>

      <!-- Bio -->
      <div class="pt-4">
        <p class="text-amber-800 font-medium tracking-[0.25em] text-xs uppercase mb-6">About me</p>
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-8 leading-tight">{settings.name}</h1>
        <p class="text-stone-600 text-lg leading-relaxed mb-10 whitespace-pre-line">
          {settings.bio}
        </p>
        <div class="flex flex-col gap-4 border-t border-stone-100 pt-8">
          {settings.email && (
            <a
              href={`mailto:${settings.email}`}
              class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors flex items-center gap-3"
            >
              <span class="text-amber-700 text-base">✉</span>
              {settings.email}
            </a>
          )}
          {settings.linkedin && (
            <a
              href={settings.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors flex items-center gap-3"
            >
              <span class="text-amber-700 text-base">↗</span>
              LinkedIn
            </a>
          )}
          {settings.instagram && (
            <a
              href={settings.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors flex items-center gap-3"
            >
              <span class="text-amber-700 text-base">↗</span>
              Instagram
            </a>
          )}
        </div>
      </div>

    </div>
  </section>
</Layout>
