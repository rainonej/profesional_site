---
import Layout from '../layouts/Layout.astro';
import Reveal from '../components/Reveal.astro';
import SectionIntro from '../components/SectionIntro.astro';
import settings from '../content/settings/main.json';
---

<Layout title={`About — ${settings.name}`} description={settings.bio}>
  <section class="mx-auto max-w-5xl px-6 pb-24 pt-40">
    <div class="grid items-start gap-20 md:grid-cols-2">
      <!-- Photo -->
      <div>
        {
          settings.photo ? (
            <img
              src={settings.photo}
              alt={settings.name}
              class="aspect-[3/4] w-full rounded-3xl object-cover"
            />
          ) : (
            <div class="flex aspect-[3/4] w-full items-center justify-center rounded-3xl bg-amber-50">
              <span class="font-serif text-9xl italic text-amber-200">
                {settings.name[0]}
              </span>
            </div>
          )
        }
      </div>

      <!-- Bio -->
      <div class="pt-4">
        <p
          class="mb-6 text-xs font-medium uppercase tracking-[0.25em] text-amber-800"
        >
          About me
        </p>
        <h1
          class="mb-8 font-serif text-4xl font-bold leading-tight md:text-5xl"
        >
          {settings.name}
        </h1>
        <p
          class="mb-10 whitespace-pre-line text-lg leading-relaxed text-stone-600"
        >
          {settings.bio}
        </p>
        <div class="flex flex-col gap-4 border-t border-stone-100 pt-8">
          {
            settings.email && (
              <a
                href={`mailto:${settings.email}`}
                class="flex items-center gap-3 text-sm font-medium text-stone-600 transition-colors hover:text-stone-900"
              >
                <span class="text-base text-amber-700">✉</span>
                {settings.email}
              </a>
            )
          }
          {
            settings.linkedin && (
              <a
                href={settings.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 text-sm font-medium text-stone-600 transition-colors hover:text-stone-900"
              >
                <span class="text-base text-amber-700">↗</span>
                LinkedIn
              </a>
            )
          }
          {
            settings.instagram && (
              <a
                href={settings.instagram}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 text-sm font-medium text-stone-600 transition-colors hover:text-stone-900"
              >
                <span class="text-base text-amber-700">↗</span>
                Instagram
              </a>
            )
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Recognition Section -->
  <Reveal
    as="section"
    class="border-t border-[var(--warm-line)] bg-[var(--paper-light)] px-6 py-24"
  >
    <div class="mx-auto max-w-5xl">
      <SectionIntro eyebrow="Recognition" heading="Awards & Honors" />
      <div class="grid items-center gap-12 md:grid-cols-2">
        <div class="order-2 md:order-1">
          <h3 class="mb-4 font-serif text-2xl font-bold">
            Shirley Chisholm Trailblazer Award
          </h3>
          <p class="mb-4 text-sm font-medium uppercase tracking-widest text-amber-800">
            Provost&apos;s Student Excellence Awards 2023-24
          </p>
          <p class="leading-relaxed text-stone-600">
            Named after Shirley Chisholm, the first Black woman elected to
            Congress and the first woman to run for President in a major party,
            this award recognizes graduate students who demonstrate exceptional
            leadership, scholarship, and commitment to social justice in
            education.
          </p>
        </div>
        <div class="order-1 md:order-2">
          <img
            src="/media/agreni-trailblazer-award.jpg"
            alt="Shirley Chisholm Trailblazer Award - Provost's Student Excellence Awards 2023-24"
            class="w-full rounded-2xl object-cover shadow-lg"
          />
        </div>
      </div>
    </div>
  </Reveal>

  <!-- Education Section -->
  <Reveal as="section" class="px-6 py-24">
    <div class="mx-auto max-w-5xl">
      <SectionIntro eyebrow="Education" heading="Academic Background" />
      <div class="grid gap-10 md:grid-cols-2">
        <div class="rounded-2xl border border-stone-100 bg-white p-8">
          <p class="mb-2 text-sm font-medium uppercase tracking-widest text-amber-800">
            M.A. Curriculum and Teaching
          </p>
          <h3 class="mb-3 font-serif text-xl font-bold">
            Teachers College, Columbia University
          </h3>
          <p class="mb-4 text-stone-500">New York, NY | 2024</p>
          <p class="text-sm leading-relaxed text-stone-600">
            Thesis: Curriculum of the Body — A Foucauldian Analysis of the
            Physical and Emotional Violence Inflicted on Female Students in
            Indian Schools
          </p>
        </div>
        <div class="rounded-2xl border border-stone-100 bg-white p-8">
          <p class="mb-2 text-sm font-medium uppercase tracking-widest text-amber-800">
            B.A. English Literature
          </p>
          <h3 class="mb-3 font-serif text-xl font-bold">
            Lady Shri Ram College, University of Delhi
          </h3>
          <p class="mb-4 text-stone-500">New Delhi, India</p>
          <p class="text-sm leading-relaxed text-stone-600">
            Foundation in literary analysis, critical theory, and the humanities
            that informs my approach to curriculum design and educational
            research.
          </p>
        </div>
      </div>
    </div>
  </Reveal>
</Layout>
