<script>
  // ── Auth ─────────────────────────────────────────────────────────────
  const gate = document.getElementById('gate')!;
  const gateStatus = document.getElementById('gate-status')!;
  const content = document.getElementById('admin-content')!;
  const logoutBtn = document.getElementById('logout-btn')!;

  function unlock() {
    gate.style.display = 'none';
    content.classList.remove('hidden');
    initDesignSystem();
    initEditors();
  }

  async function checkSession() {
    try {
      const res = await fetch('/api/auth/session');
      if (!res.ok) throw new Error('no session endpoint');
      const data = await res.json();
      if (data.authenticated) {
        unlock();
      } else {
        gateStatus.textContent = 'Redirecting to GitHub…';
        window.location.href = '/api/auth/github';
      }
    } catch {
      gateStatus.textContent = 'Admin unavailable in this environment.';
    }
  }

  checkSession();

  logoutBtn.addEventListener('click', () => {
    window.location.href = '/api/auth/logout';
  });

  // ── Design tokens ────────────────────────────────────────────────────
  function initDesignSystem() {
    const style = getComputedStyle(document.documentElement);
    const tokens = [
      { name: '--paper', label: 'Paper', usage: 'Page background' },
      {
        name: '--paper-light',
        label: 'Paper Light',
        usage: 'Section backgrounds, cards',
      },
      {
        name: '--ink',
        label: 'Ink',
        usage: 'Headings, body text, primary button',
      },
      {
        name: '--stone-soft',
        label: 'Stone Soft',
        usage: 'Secondary text, captions, metadata',
      },
      {
        name: '--copper',
        label: 'Copper',
        usage: 'Eyebrows, links, accent highlights',
      },
      { name: '--clay', label: 'Clay', usage: 'Hover states, warmer accent' },
      {
        name: '--warm-line',
        label: 'Warm Line',
        usage: 'Borders, dividers, separators',
      },
      {
        name: '--pale-sand',
        label: 'Pale Sand',
        usage: 'Testimonials section, pillars bg',
      },
      { name: '--olive', label: 'Olive', usage: 'Tags, decorative accents' },
    ];

    const container = document.getElementById('color-swatches')!;
    tokens.forEach(({ name, label, usage }) => {
      const value = style.getPropertyValue(name).trim();
      const swatch = document.createElement('div');
      swatch.className =
        'rounded-xl overflow-hidden border border-[var(--warm-line)]';
      swatch.innerHTML = `
        <div style="background:${value}; height: 80px;"></div>
        <div class="p-3 bg-[var(--paper-light)]">
          <p class="text-xs font-semibold text-[var(--ink)]">${label}</p>
          <p class="text-xs text-[var(--stone-soft)] font-mono mt-0.5">${value}</p>
          <p class="text-xs text-[var(--stone-soft)] font-mono">${name}</p>
          <p class="mt-1.5 text-xs text-[var(--stone-soft)] opacity-70 leading-snug">${usage}</p>
        </div>
      `;
      container.appendChild(swatch);
    });
  }

  // ── Content editors ──────────────────────────────────────────────────
  function initEditors() {
    initSettingsEditor();
    initModal();
    initContentButtons();
  }

  // ── Content API ──────────────────────────────────────────────────────
  const API = {
    async get(path: string): Promise<{ sha: string; content: string }> {
      const res = await fetch(`/api/content?path=${encodeURIComponent(path)}`);
      if (!res.ok) {
        const err = (await res.json().catch(() => ({}))) as { error?: string };
        throw new Error(err.error ?? `GET failed: ${res.status}`);
      }
      return res.json();
    },

    async put(
      path: string,
      fileContent: string,
      sha: string | undefined,
      message: string
    ): Promise<void> {
      const body: Record<string, string> = {
        path,
        content: fileContent,
        message,
      };
      if (sha) body['sha'] = sha;
      const res = await fetch('/api/content', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (!res.ok) {
        const err = (await res.json().catch(() => ({}))) as { error?: string };
        throw new Error(err.error ?? `Save failed: ${res.status}`);
      }
    },

    async delete(path: string, sha: string, message: string): Promise<void> {
      const res = await fetch('/api/content', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ path, sha, message }),
      });
      if (!res.ok) {
        const err = (await res.json().catch(() => ({}))) as { error?: string };
        throw new Error(err.error ?? `Delete failed: ${res.status}`);
      }
    },
  };

  // ── Decode base64 (UTF-8 safe) ───────────────────────────────────────
  function decodeB64(b64: string): string {
    const binStr = atob(b64.replace(/\n/g, ''));
    const bytes = new Uint8Array(binStr.length);
    for (let i = 0; i < binStr.length; i++) bytes[i] = binStr.charCodeAt(i);
    return new TextDecoder().decode(bytes);
  }

  // ── Frontmatter parser ───────────────────────────────────────────────
  // Handles the YAML subset used in this repo: strings (single/double
  // quoted or bare), booleans, dates, arrays, and >- block scalars.
  // Serialises back to a consistent double-quoted style so diffs stay clean.
  const FM = {
    parse(raw: string): { data: Record<string, unknown>; body: string } {
      const m = raw.match(/^---\r?\n([\s\S]*?)\r?\n---(?:\r?\n|$)([\s\S]*)/);
      if (!m) return { data: {}, body: raw };
      const data: Record<string, unknown> = {};
      const lines = m[1].split('\n');
      let i = 0;
      while (i < lines.length) {
        const line = lines[i];
        if (!line.trim()) {
          i++;
          continue;
        }

        // Block scalar: key: >- or key: |
        const bsKey = line.match(/^(\w[\w-]*):\s*[>|]/)?.[1];
        if (bsKey) {
          const parts: string[] = [];
          i++;
          while (i < lines.length && /^\s/.test(lines[i])) {
            parts.push(lines[i].trim());
            i++;
          }
          data[bsKey] = parts.join(' ');
          continue;
        }

        const colonIdx = line.indexOf(':');
        if (colonIdx === -1) {
          i++;
          continue;
        }
        const key = line.slice(0, colonIdx).trim();
        const rest = line.slice(colonIdx + 1).trim();

        // Array
        if (rest === '' || rest === '[]') {
          const items: string[] = [];
          i++;
          while (i < lines.length && /^\s*-/.test(lines[i])) {
            items.push(
              lines[i]
                .replace(/^\s*-\s*/, '')
                .trim()
                .replace(/^['"]|['"]$/g, '')
            );
            i++;
          }
          data[key] = items;
          continue;
        }

        if (rest === 'true') data[key] = true;
        else if (rest === 'false') data[key] = false;
        else data[key] = rest.replace(/^['"]|['"]$/g, '');
        i++;
      }
      return { data, body: (m[2] ?? '').trimStart() };
    },

    stringify(data: Record<string, unknown>, body: string): string {
      let yaml = '---\n';
      for (const [key, val] of Object.entries(data)) {
        if (val === undefined || val === null || val === '') continue;
        if (Array.isArray(val)) {
          if ((val as unknown[]).length === 0) {
            yaml += `${key}: []\n`;
            continue;
          }
          yaml += `${key}:\n`;
          for (const item of val as string[])
            yaml += `  - ${JSON.stringify(String(item))}\n`;
        } else if (typeof val === 'boolean') {
          yaml += `${key}: ${val}\n`;
        } else {
          yaml += `${key}: ${JSON.stringify(String(val))}\n`;
        }
      }
      yaml += '---\n';
      if (body.trim()) yaml += '\n' + body.trimEnd() + '\n';
      return yaml;
    },
  };

  // ── Slug utility ─────────────────────────────────────────────────────
  function slugify(str: string): string {
    return str
      .toLowerCase()
      .replace(/[^\w\s-]/g, '')
      .replace(/[\s_]+/g, '-')
      .replace(/^-+|-+$/g, '');
  }

  // ── Toast ─────────────────────────────────────────────────────────────
  const toastEl = document.getElementById('toast')!;
  let toastTimer: ReturnType<typeof setTimeout>;

  function showToast(msg: string, isError = false) {
    toastEl.textContent = msg;
    toastEl.className = `toast-show ${isError ? 'toast-error' : 'toast-ok'}`;
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => {
      toastEl.className = isError ? 'toast-error' : 'toast-ok';
    }, 4000);
  }

  // ── Modal ──────────────────────────────────────────────────────────────
  const modalEl = document.getElementById('edit-modal') as HTMLDialogElement;
  const modalTitleEl = document.getElementById('modal-title')!;
  const modalFieldsEl = document.getElementById('modal-fields')!;
  const modalSaveBtn = document.getElementById(
    'modal-save-btn'
  ) as HTMLButtonElement;
  const modalDeleteBtn = document.getElementById(
    'modal-delete-btn'
  ) as HTMLButtonElement;
  const modalCancelBtn = document.getElementById('modal-cancel-btn')!;
  const modalCloseBtn = document.getElementById('modal-close-btn')!;

  type FieldDef = {
    name: string;
    label: string;
    type?: string;
    rows?: number;
    value?: unknown;
  };

  let _onSave: ((vals: Record<string, unknown>) => Promise<void>) | null = null;
  let _onDelete: (() => Promise<void>) | null = null;

  function initModal() {
    modalSaveBtn.addEventListener('click', async () => {
      if (!_onSave) return;
      modalSaveBtn.disabled = true;
      modalSaveBtn.textContent = 'Saving…';
      try {
        await _onSave(readModalForm());
        modalEl.close();
        showToast('Saved — committed to dev');
        window.location.reload();
      } catch (e: unknown) {
        showToast((e as Error).message, true);
        modalSaveBtn.disabled = false;
        modalSaveBtn.textContent = 'Save';
      }
    });

    modalDeleteBtn.addEventListener('click', async () => {
      if (!_onDelete) return;
      if (!confirm('Delete this entry? This cannot be undone.')) return;
      modalDeleteBtn.disabled = true;
      try {
        await _onDelete();
        modalEl.close();
        showToast('Deleted — committed to dev');
        window.location.reload();
      } catch (e: unknown) {
        showToast((e as Error).message, true);
        modalDeleteBtn.disabled = false;
      }
    });

    modalCancelBtn.addEventListener('click', () => modalEl.close());
    modalCloseBtn.addEventListener('click', () => modalEl.close());
    modalEl.addEventListener('click', (e) => {
      if (e.target === modalEl) modalEl.close();
    });
  }

  function openModal(opts: {
    title: string;
    fields: FieldDef[];
    onSave: (vals: Record<string, unknown>) => Promise<void>;
    onDelete?: () => Promise<void>;
  }) {
    modalTitleEl.textContent = opts.title;
    modalFieldsEl.innerHTML = renderFields(opts.fields);
    modalSaveBtn.disabled = false;
    modalSaveBtn.textContent = 'Save';
    modalDeleteBtn.style.display = opts.onDelete ? 'block' : 'none';
    modalDeleteBtn.disabled = false;
    _onSave = opts.onSave;
    _onDelete = opts.onDelete ?? null;
    modalEl.showModal();
  }

  function renderFields(fields: FieldDef[]): string {
    return fields
      .map((f) => {
        const id = `mf-${f.name}`;
        const safeVal = String(f.value ?? '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');

        if (f.type === 'checkbox') {
          return `<div class="modal-field">
            <label class="modal-checkbox-row">
              <input type="checkbox" id="${id}" name="${f.name}" ${f.value ? 'checked' : ''}>
              ${f.label}
            </label>
          </div>`;
        }
        if (f.type === 'textarea') {
          return `<div class="modal-field">
            <label class="modal-label" for="${id}">${f.label}</label>
            <textarea id="${id}" name="${f.name}" class="modal-input modal-textarea" rows="${f.rows ?? 4}">${safeVal}</textarea>
          </div>`;
        }
        return `<div class="modal-field">
          <label class="modal-label" for="${id}">${f.label}</label>
          <input type="${f.type ?? 'text'}" id="${id}" name="${f.name}" class="modal-input" value="${safeVal}">
        </div>`;
      })
      .join('');
  }

  function readModalForm(): Record<string, unknown> {
    const result: Record<string, unknown> = {};
    for (const el of Array.from(
      modalFieldsEl.querySelectorAll('input, textarea, select')
    )) {
      const inp = el as HTMLInputElement | HTMLTextAreaElement;
      if (!inp.name) continue;
      result[inp.name] =
        inp.type === 'checkbox' ? (inp as HTMLInputElement).checked : inp.value;
    }
    return result;
  }

  // ── Content buttons wiring ───────────────────────────────────────────
  function initContentButtons() {
    document.querySelectorAll('.edit-entry-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        openContentEditor(el.dataset.type!, el.dataset.slug!);
      });
    });

    document.querySelectorAll('.new-entry-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        openContentEditor((btn as HTMLElement).dataset.type!, null);
      });
    });
  }

  // ── Dispatcher ────────────────────────────────────────────────────────
  async function openContentEditor(type: string, slug: string | null) {
    if (type === 'project') await openMarkdownEditor(slug, 'project');
    else if (type === 'writing') await openMarkdownEditor(slug, 'writing');
    else if (type === 'testimonial') await openTestimonialEditor(slug);
  }

  // ── Markdown editor (projects + writing) ─────────────────────────────
  function collectionPath(type: string, slug: string) {
    const dir = type === 'project' ? 'projects' : 'writing';
    return `site/src/content/${dir}/${slug}.md`;
  }

  function markdownFields(
    type: string,
    d: Record<string, unknown> = {}
  ): FieldDef[] {
    const base: FieldDef[] = [
      { name: 'title', label: 'Title', value: d.title },
      {
        name: 'description',
        label: 'Description',
        type: 'textarea',
        rows: 3,
        value: d.description,
      },
      { name: 'date', label: 'Date (YYYY-MM-DD)', value: d.date },
      {
        name: 'tags',
        label: 'Tags (comma-separated)',
        value: Array.isArray(d.tags)
          ? (d.tags as string[]).join(', ')
          : (d.tags ?? ''),
      },
      { name: 'image', label: 'Image path', value: d.image },
    ];
    if (type === 'project') {
      base.push({ name: 'link', label: 'External link (URL)', value: d.link });
    }
    base.push({
      name: 'featured',
      label: 'Featured',
      type: 'checkbox',
      value: d.featured,
    });
    if (type === 'writing') {
      base.push({
        name: 'draft',
        label: 'Draft (hidden from site)',
        type: 'checkbox',
        value: d.draft,
      });
    }
    base.push({
      name: 'body',
      label: 'Body (Markdown)',
      type: 'textarea',
      rows: 14,
      value: d._body,
    });
    return base;
  }

  async function openMarkdownEditor(slug: string | null, type: string) {
    let sha: string | undefined;
    let existingData: Record<string, unknown> = {};

    if (slug) {
      try {
        const { sha: s, content } = await API.get(collectionPath(type, slug));
        sha = s;
        const { data, body } = FM.parse(decodeB64(content));
        existingData = { ...data, _body: body };
      } catch (e: unknown) {
        showToast((e as Error).message, true);
        return;
      }
    }

    const typeLabel = type === 'project' ? 'Project' : 'Essay';

    openModal({
      title: slug ? `Edit ${typeLabel}` : `New ${typeLabel}`,
      fields: markdownFields(type, existingData),
      onSave: async (vals) => {
        const title = (vals.title as string).trim();
        if (!title) throw new Error('Title is required');

        const tags = (vals.tags as string)
          .split(',')
          .map((t) => t.trim())
          .filter(Boolean);

        const fmData: Record<string, unknown> = {
          title,
          description: vals.description || undefined,
          date: vals.date || new Date().toISOString().slice(0, 10),
          tags,
          image: vals.image || undefined,
          featured: !!vals.featured,
        };
        if (type === 'project' && vals.link) fmData['link'] = vals.link;
        if (type === 'writing') fmData['draft'] = !!vals.draft;

        const fileContent = FM.stringify(fmData, (vals.body as string) || '');
        const targetSlug = slug ?? slugify(title);
        const verb = slug ? 'update' : 'add';
        const dir = type === 'project' ? 'project' : 'essay';
        await API.put(
          collectionPath(type, targetSlug),
          fileContent,
          sha,
          `content: ${verb} ${dir} "${title}"`
        );
      },
      onDelete: slug
        ? async () => {
            await API.delete(
              collectionPath(type, slug),
              sha!,
              `content: delete ${type === 'project' ? 'project' : 'essay'} "${slug}"`
            );
          }
        : undefined,
    });
  }

  // ── Testimonial editor ────────────────────────────────────────────────
  const TESTIMONIALS_DIR = 'site/src/content/testimonials';

  async function openTestimonialEditor(slug: string | null) {
    let sha: string | undefined;
    let d: Record<string, unknown> = {};

    if (slug) {
      try {
        const { sha: s, content } = await API.get(
          `${TESTIMONIALS_DIR}/${slug}.json`
        );
        sha = s;
        d = JSON.parse(decodeB64(content));
      } catch (e: unknown) {
        showToast((e as Error).message, true);
        return;
      }
    }

    openModal({
      title: slug ? 'Edit Testimonial' : 'New Testimonial',
      fields: [
        { name: 'author', label: 'Author', value: d.author },
        { name: 'role', label: 'Role / Title', value: d.role },
        {
          name: 'quote',
          label: 'Quote',
          type: 'textarea',
          rows: 5,
          value: d.quote,
        },
        {
          name: 'featured',
          label: 'Featured',
          type: 'checkbox',
          value: d.featured,
        },
      ],
      onSave: async (vals) => {
        const author = (vals.author as string).trim();
        if (!author) throw new Error('Author is required');

        const payload = {
          author,
          role: vals.role || undefined,
          quote: (vals.quote as string).trim(),
          featured: !!vals.featured,
        };

        const targetSlug = slug ?? slugify(author);
        const verb = slug ? 'update' : 'add';
        await API.put(
          `${TESTIMONIALS_DIR}/${targetSlug}.json`,
          JSON.stringify(payload, null, 2) + '\n',
          sha,
          `content: ${verb} testimonial from "${author}"`
        );
      },
      onDelete: slug
        ? async () => {
            await API.delete(
              `${TESTIMONIALS_DIR}/${slug}.json`,
              sha!,
              `content: delete testimonial "${slug}"`
            );
          }
        : undefined,
    });
  }

  // ── Settings editor ───────────────────────────────────────────────────
  const SETTINGS_PATH = 'site/src/content/settings/main.json';

  function initSettingsEditor() {
    const displayEl = document.getElementById('settings-display')!;
    const formEl = document.getElementById('settings-form') as HTMLFormElement;
    const editBtn = document.getElementById('settings-edit-btn')!;
    const cancelBtn = document.getElementById('settings-cancel-btn')!;

    editBtn.addEventListener('click', async () => {
      displayEl.classList.add('hidden');
      formEl.classList.remove('hidden');
      try {
        const { sha, content } = await API.get(SETTINGS_PATH);
        const json = JSON.parse(decodeB64(content)) as Record<string, string>;
        formEl.dataset['sha'] = sha;
        for (const [k, v] of Object.entries(json)) {
          const el = formEl.querySelector<
            HTMLInputElement | HTMLTextAreaElement
          >(`[name="${k}"]`);
          if (el) el.value = v ?? '';
        }
      } catch (e: unknown) {
        showToast('Failed to load settings: ' + (e as Error).message, true);
        displayEl.classList.remove('hidden');
        formEl.classList.add('hidden');
      }
    });

    cancelBtn.addEventListener('click', () => {
      displayEl.classList.remove('hidden');
      formEl.classList.add('hidden');
    });

    formEl.addEventListener('submit', async (e) => {
      e.preventDefault();
      const sha = formEl.dataset['sha'];
      const data: Record<string, string> = {};
      for (const el of Array.from(formEl.elements) as HTMLInputElement[]) {
        if (el.name) data[el.name] = el.value;
      }
      const submitBtn =
        formEl.querySelector<HTMLButtonElement>('[type="submit"]')!;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Saving…';
      try {
        await API.put(
          SETTINGS_PATH,
          JSON.stringify(data, null, 2) + '\n',
          sha,
          'content: update settings'
        );
        showToast('Settings saved — committed to dev');
        window.location.reload();
      } catch (err: unknown) {
        showToast((err as Error).message, true);
        submitBtn.disabled = false;
        submitBtn.textContent = 'Save settings';
      }
    });
  }
</script>
