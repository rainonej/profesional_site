---
const base = '/professional_site';
const navLinks = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/research/`, label: 'Research' },
  { href: `${base}/teaching/`, label: 'Teaching' },
  { href: `${base}/writing/`, label: 'Writing' },
  { href: `${base}/contact/`, label: 'Book' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white border-b border-slate-200">
  <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href={`${base}/`} class="font-serif text-lg font-semibold text-slate-900 no-underline hover:text-indigo-600 transition-colors">
      Agreni Batra
    </a>
    <nav>
      <ul class="flex items-center gap-6 list-none m-0 p-0">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class={`text-sm font-medium no-underline transition-colors ${
                currentPath === href || currentPath === href.replace(/\/$/, '')
                  ? 'text-indigo-600'
                  : 'text-slate-600 hover:text-indigo-600'
              }`}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
