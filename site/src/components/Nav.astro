---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const links = [
  { href: `${base}/about`, label: 'About' },
  { href: `${base}/work`, label: 'Work' },
  { href: `${base}/contact`, label: 'Contact' },
];

const { pathname } = Astro.url;
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-stone-100 bg-stone-50/80 backdrop-blur-md"
>
  <nav class="mx-auto flex h-16 max-w-5xl items-center justify-between px-6">
    <a
      href={`${base}/`}
      class="font-serif text-xl font-bold tracking-tight transition-opacity hover:opacity-60"
    >
      Agreni
    </a>
    <ul class="flex items-center gap-8">
      {
        links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class={`text-sm font-medium transition-colors ${
                pathname.startsWith(href)
                  ? 'text-stone-900'
                  : 'text-stone-400 hover:text-stone-900'
              }`}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
