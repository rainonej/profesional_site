---
interface Props {
  title: string;
  description?: string;
  date: Date;
  slug: string;
}

const { title, description, date, slug } = Astro.props;
const base = '/professional_site';

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="border-b border-slate-100 pb-8 mb-8 last:border-b-0 last:mb-0">
  <time class="text-sm text-slate-500 font-sans" datetime={date.toISOString()}>
    {formattedDate}
  </time>
  <h2 class="text-xl font-serif font-semibold mt-1 mb-2">
    <a href={`${base}/writing/${slug}/`} class="text-slate-900 no-underline hover:text-indigo-600 transition-colors">
      {title}
    </a>
  </h2>
  {description && (
    <p class="text-slate-600 text-sm leading-relaxed">{description}</p>
  )}
  <a href={`${base}/writing/${slug}/`} class="text-sm text-indigo-600 mt-2 inline-block hover:underline">
    Read →
  </a>
</article>
