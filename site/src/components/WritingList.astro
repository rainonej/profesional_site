---
interface Post {
  id: string;
  title: string;
  date: Date;
  description?: string;
  image?: string;
  href: string;
}

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

<ul class="space-y-10">
  {
    posts.map((post) => (
      <li class="group">
        {post.image && (
          <a href={post.href} class="mb-4 block">
            <div class="aspect-[21/9] overflow-hidden rounded-xl bg-stone-100">
              <img
                src={post.image}
                alt={post.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>
          </a>
        )}
        <time
          class="mb-1.5 block text-xs text-stone-400"
          datetime={post.date.toISOString()}
        >
          {post.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
          })}
        </time>
        <h3 class="mb-1.5 font-serif text-xl font-bold leading-snug">
          <a
            href={post.href}
            class="transition-colors hover:text-[var(--copper)]"
          >
            {post.title}
          </a>
        </h3>
        {post.description && (
          <p class="text-sm leading-relaxed text-stone-500">
            {post.description}
          </p>
        )}
      </li>
    ))
  }
</ul>
