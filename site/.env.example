# GitHub OAuth App credentials (required for /admin auth on Vercel)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Session signing secret — generate a long random string, do not commit the real value
SESSION_SECRET=

# GitHub repo used for collaborator auth check (callback.ts) and content API (content.ts).
# Format: owner/repo — override when deploying to a fork or renamed repo.
REPO_OWNER=rainonej
REPO_NAME=profesional_site
GITHUB_REPO=rainonej/profesional_site
